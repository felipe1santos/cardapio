# ============================================================================
# Supabase — copie este arquivo para .env.local e preencha com as chaves do seu
# projeto (Supabase Dashboard › Project Settings › API e › Database).
# ============================================================================

# Project Settings › API › Project URL
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co

# Project Settings › API › Project API keys › anon / public
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Project Settings › API › Project API keys › service_role  (SECRETA — só no servidor)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Botão "Connect" (topo do dashboard) › ORM/psql › connection string.
# Use a string com a SENHA do banco já embutida. Ex.:
# postgresql://postgres.abcdxyz:SUA_SENHA@aws-0-sa-east-1.pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://postgres:YOUR_DB_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# ----------------------------------------------------------------------------
# Seed inicial — usado UMA vez por `node scripts/setup-db.mjs` para criar sua
# primeira loja e seu usuário admin (login do painel). Pode trocar à vontade.
# ----------------------------------------------------------------------------
SEED_LOJA_NOME=Minha Loja
SEED_LOJA_SLUG=minha-loja
SEED_ADMIN_EMAIL=voce@exemplo.com
SEED_ADMIN_PASSWORD=troque-esta-senha
SEED_ADMIN_NOME=Seu Nome

# ----------------------------------------------------------------------------
# Evolution API — envia mensagens de WhatsApp para o cliente a cada etapa do
# pedido (recebido, aceito/resumo, pronto, saiu para entrega). Globais e do
# servidor (apikey de administração da sua Evolution API). Opcional: se
# qualquer uma das duas variáveis abaixo faltar, o envio é apenas pulado.
#
# Cada restaurante conecta seu PRÓPRIO número em Ajustes > Integrações (gera
# uma instância por loja, conectada via QR code) — não precisa de uma
# EVOLUTION_INSTANCE fixa aqui.
# ----------------------------------------------------------------------------
EVOLUTION_API_URL=https://sua-evolution-api.com
EVOLUTION_API_KEY=sua-api-key

# ----------------------------------------------------------------------------
# Google Maps — usado no portal do entregador (/entregador/[token]) para
# mostrar o mapa com a rota das entregas atribuídas. Pública (NEXT_PUBLIC_),
# vai pro bundle do navegador — restrinja a chave por domínio no Google Cloud.
# ----------------------------------------------------------------------------
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=sua-chave-google-maps
