{
  "name": "menuzia-printer-agent",
  "version": "0.1.19",
  "description": "Assistente de Impressão Menuzia — liga o painel na nuvem à impressora instalada no computador da loja.",
  "main": "src/main.js",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.menuzia.printeragent",
    "productName": "Assistente de Impressão Menuzia",
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowElevation": false,
      "runAfterFinish": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Assistente de Impressão Menuzia",
      "artifactName": "AssistenteImpressaoMenuzia-Setup-${version}.${ext}"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "src/*.ps1"
    ]
  }
}
